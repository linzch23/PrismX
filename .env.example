# 模型提供方：deepseek、anthropic 或 openai-compatible。
MY_AGENT_PROVIDER=deepseek

# DeepSeek 是默认提供方。
DEEPSEEK_API_KEY=请填写_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic 提供方。
# ANTHROPIC_API_KEY=请填写_anthropic_api_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 通用 OpenAI-compatible 提供方。
# OPENAI_COMPATIBLE_API_KEY=请填写_api_key
# OPENAI_COMPATIBLE_BASE_URL=https://api.example.com/v1

# 可选：mcp_servers.json 中的 Tavily MCP server 需要此变量。
# TAVILY_API_KEY=请填写_tavily_api_key

# 可选运行配置。
MY_AGENT_MODEL=deepseek-chat
MY_AGENT_WORKSPACE=.
MY_AGENT_MAX_TOKENS=4096
MY_AGENT_MAX_CONTEXT_TOKENS=64000
MY_AGENT_COMPACT_THRESHOLD=0.7
MY_AGENT_COMPACT_KEEP_MESSAGES=8
MY_AGENT_STARTUP_COMPACTION=0
